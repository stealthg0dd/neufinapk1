{
  "name": "neufin-mobile",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "build:apk": "eas build --platform android --profile preview",
    "ios": "expo run:ios",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "tsc": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|posthog-react-native|nativewind|react-native-reanimated|react-native-worklets)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "\\.css$": "<rootDir>/__mocks__/styleMock.js",
      "^react-native-reanimated$": "<rootDir>/__mocks__/react-native-reanimated.js"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/android/",
      "/ios/",
      "/dist/"
    ],
    "globals": {
      "__DEV__": true
    }
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "3.0.2",
    "@react-navigation/bottom-tabs": "^7.16.0",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/stack": "^7.9.0",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.99.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.17",
    "expo-blur": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.2.3",
    "posthog-react-native": "^3.16.1",
    "react": "19.1.0",
    "react-native": "0.85.3",
    "react-native-chart-kit": "^6.12.2",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.0",
    "react-native-svg": "15.15.5",
    "react-native-view-shot": "5.1.0",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  }
}
