# Supabase — get from Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
# Optional: force exact redirect URI used for OAuth callback matching.
# Example (Expo Go): exp://192.168.1.10:8081/--/auth/callback
# Example (native):   neufin://auth/callback
EXPO_PUBLIC_SUPABASE_REDIRECT_URI=

# Backend API — Railway URL in production, localhost in local dev
EXPO_PUBLIC_API_URL=https://<your-app>.up.railway.app

# Monitoring — get from https://sentry.io → New Project
EXPO_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
