# Anthropic (required — used only for LLM fix generation)
ANTHROPIC_API_KEY=sk-ant-api03-...

# GitHub (required — enables PR creation + issue auto-ticketing)
GITHUB_TOKEN=ghp_...
GITHUB_ORG=stealthg0dd
GITHUB_REPO=stealthg0dd/neufinapk1

# Supabase (required — scan persistence)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key, not anon key

# Slack — multi-channel routing (all required)
SLACK_WEBHOOK_NEUFIN_ALERTS=https://hooks.slack.com/services/...    # CRITICAL → #neufin-alerts
SLACK_WEBHOOK_NEUFIN_DEV=https://hooks.slack.com/services/...       # HIGH + digest → #neufin-dev
SLACK_WEBHOOK_CTECH_COMMAND=https://hooks.slack.com/services/...    # CRITICAL → #ctech-command
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...              # Legacy single webhook (backward compat)

# Sentry (required)
SENTRY_DSN=https://...@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=sntrys_...

# Router-system / Agent OS (required)
AGENT_OS_URL=https://ctech-production.up.railway.app
AGENT_OS_API_KEY=...

# Sentry webhook receiver auth (optional)
SENTRY_WEBHOOK_SECRET=

# Vercel (optional — enables Web Vitals + error rate polling)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# Railway backend URL (override default)
RAILWAY_HEALTH_URL=https://neufin101-production.up.railway.app/health

# GitHub PR settings
GITHUB_ASSIGNEE=varun
PR_BASE_BRANCH=develop   # PRs target this branch, not main

# Email / SMTP (for critical-only email alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@neufin.ai
SMTP_PASS=
ALERT_EMAIL=varun@neufin.ai
FROM_EMAIL=alerts@neufin.ai

# Dashboard public URL (used in Slack message footers)
DASHBOARD_URL=http://localhost:8001/dashboard

# Agent settings
SCAN_INTERVAL_HOURS=6   # how often APScheduler runs a full scan
AGENT_PORT=8001
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
