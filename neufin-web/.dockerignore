# Dependencies — installed fresh inside the container
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build output — produced inside the container
.next/
out/

# Environment files — never bake secrets into the image
.env
.env.*
!.env.example

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# Git
.git/
.gitignore

# Tests
coverage/
.nyc_output/

# Docs
*.md
