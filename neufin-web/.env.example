# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── Backend API ───────────────────────────────────────────────────────────────
# Browser bundle — used by client-side fetch calls.
#   Local dev:  http://localhost:8080
#   Production (Vercel): set to your Vercel domain (e.g. https://neufin-web.vercel.app)
#   so calls go to the same-origin Vercel proxy and never hit Railway directly.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Server-only — used by next.config.js rewrite destination (never sent to browser).
# Always point this at Railway. Vercel edge proxy forwards /api/* here.
# Set this in the Vercel dashboard under Environment Variables (not NEXT_PUBLIC_*).
RAILWAY_API_URL=https://neufin101-production.up.railway.app

# ── App URL ───────────────────────────────────────────────────────────────────
# Used for OG/social sharing meta tags and absolute URLs.
# NEXT_PUBLIC_SITE_URL must EXACTLY match the value set in:
#   Supabase → Auth → URL Configuration → Site URL
# Also add  <NEXT_PUBLIC_SITE_URL>/auth/callback  to Supabase Redirect URLs.
# Mismatch between these values causes the Google OAuth redirect loop.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── PostHog Analytics (optional) ─────────────────────────────────────────────
# Get from: https://us.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=<your-posthog-project-api-key>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── CTech Agent OS ─────────────────────────────────────────────────────────────
# Server-only — the URL and API key for the multi-LLM agent backend.
# Never use NEXT_PUBLIC_ prefix here — these must NOT reach the browser.
# Local dev: http://localhost:8001 (run `uvicorn main:app --port 8001` in router_system/)
# Production: your Agent OS Railway URL (a separate Railway service from neufin101)
AGENT_OS_URL=http://localhost:8001
AGENT_OS_API_KEY=<your-agent-os-api-key>
