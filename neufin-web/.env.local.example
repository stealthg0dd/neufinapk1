# ── Supabase (from: supabase.com → Project Settings → API) ───────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── Site URL — MUST match Supabase → Auth → URL Configuration → Site URL ─────
# Local dev:   http://localhost:3000
# Production:  https://neufin-web.vercel.app  (set this in Vercel env vars as well)
#
# Supabase uses this to validate OAuth redirect_to parameters.
# Mismatch here causes the Google auth loop (JWKS miss + redirect failure).
# Also add  <NEXT_PUBLIC_SITE_URL>/auth/callback  to Supabase → Auth → Redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Backend API (Railway URL after deploy) ────────────────────────────────────
NEXT_PUBLIC_API_URL=https://neufin-api.railway.app

# ── PostHog analytics (from: app.posthog.com → Project Settings → API Keys) ──
NEXT_PUBLIC_POSTHOG_KEY=phc_<your-posthog-project-key>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
