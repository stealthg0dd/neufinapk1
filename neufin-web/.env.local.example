# ── Supabase (from: supabase.com → Project Settings → API) ───────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── Backend API (Railway URL after deploy) ────────────────────────────────────
NEXT_PUBLIC_API_URL=https://neufin-api.railway.app

# ── PostHog analytics (from: app.posthog.com → Project Settings → API Keys) ──
NEXT_PUBLIC_POSTHOG_KEY=phc_<your-posthog-project-key>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
