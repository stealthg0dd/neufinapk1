# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# ── Site / App URLs ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=https://YOUR_RAILWAY_BACKEND_URL_HERE

# ── Backend API (neufin-backend) ──────────────────────────────────────────────
PORT=8000
DATABASE_URL=YOUR_POSTGRES_DATABASE_URL_HERE
JWT_SECRET=YOUR_JWT_SECRET_HERE

# ── Analytics ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_YOUR_POSTHOG_KEY_HERE
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── neufin-agent ──────────────────────────────────────────────────────────────
AGENT_PORT=8001
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE
GITHUB_REPO=stealthg0dd/neufin
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
ENVIRONMENT=production
LOG_LEVEL=INFO
DASHBOARD_URL=https://YOUR_DASHBOARD_URL_HERE
ALERT_EMAIL=YOUR_ALERT_EMAIL_HERE
FROM_EMAIL=YOUR_FROM_EMAIL_HERE
