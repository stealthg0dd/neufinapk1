# Python artifacts
__pycache__/
*.pyc
*.py[cod]
*.pyo
*.pyd
.Python
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Test artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
tests/

# Dev dependencies (not needed at runtime)
requirements-dev.txt

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Environment files — never bake secrets into the image
.env
.env.*
!.env.example

# Git
.git/
.gitignore

# Docs / logs
*.md
*.log

# Scripts (smoke tests, migrations) — not needed at runtime
scripts/

# Alembic and SQL migration files — run separately, not at container start
alembic/
supabase/
*.sql

# Ruff / other tool caches
.ruff_cache/
.mypy_cache/
