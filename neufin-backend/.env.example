# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<your-supabase-anon-key>
# Service role key — bypasses RLS for system writes
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ── Market Data (fallback chain: Polygon → FMP → TwelveData → Marketstack → Finnhub → Alpha Vantage) ──
# Get from: https://polygon.io/dashboard
POLYGON_API_KEY=<your-polygon-api-key>
# Get from: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=<your-fmp-api-key>
# Get from: https://twelvedata.com/account/api-keys
TWELVEDATA_API_KEY=<your-twelvedata-api-key>
# Get from: https://marketstack.com/dashboard
MARKETSTACK_API_KEY=<your-marketstack-api-key>
# Get from: https://finnhub.io/dashboard
FINNHUB_API_KEY=<your-finnhub-api-key>
# Get from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=<your-alpha-vantage-api-key>
# Get from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=<your-fred-api-key>

# ── AI Models (fallback chain: Claude → Gemini → Groq) ───────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# Get from: https://makersuite.google.com/app/apikey
GEMINI_KEY=<your-gemini-api-key>
# Optional — reserved for future use
OPENAI_KEY=<your-openai-api-key>
# Get from: https://console.groq.com/keys
GROQ_KEY=<your-groq-api-key>

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_<your-stripe-secret-key>
# Get from: Stripe Dashboard → Developers → Webhooks → signing secret
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-signing-secret>
# Create in Stripe Dashboard → Products — single report one-time $29
STRIPE_PRICE_SINGLE_REPORT=price_<your-single-report-price-id>
# Unlimited advisor recurring $99/mo
STRIPE_PRICE_UNLIMITED_MONTHLY=price_<your-unlimited-monthly-price-id>
# Create coupon in Stripe Dashboard → Products → Coupons (ID must be REFER20, 20% off)
STRIPE_REFERRAL_COUPON_ID=REFER20

# ── Monitoring ────────────────────────────────────────────────────────────────
# Get from: https://sentry.io → New Project → DSN
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# Optional: override sampling rates (default 0.1 = 10 %)
SENTRY_TRACES_SAMPLE_RATE=0.1
# Sentry CLI / CI — for source map uploads
SENTRY_ORG=<your-sentry-org-slug>
SENTRY_PROJECT=neufin-backend
SENTRY_AUTH_TOKEN=<your-sentry-auth-token>

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_FORMAT: "json" (production default) | "console" (local dev)
LOG_FORMAT=json
LOG_LEVEL=INFO

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://<your-vercel-app>.vercel.app
APP_ENV=production
PORT=8000
