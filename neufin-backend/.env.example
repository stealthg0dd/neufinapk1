# ─────────────────────────────────────────────────────────────────────────────
# NeuFin Backend — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# REQUIRED variables must be set before the app will start.
# Optional variables enable additional features (AI, market data, etc.)
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployment environment (REQUIRED) ────────────────────────────────────────
# Values: development | staging | production
ENVIRONMENT=development

# ── Supabase (REQUIRED) ───────────────────────────────────────────────────────
# Your Supabase project URL. Dashboard → Settings → API → URL.
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon (public) key. Dashboard → Settings → API → anon public.
SUPABASE_KEY=your-supabase-anon-key

# Supabase service-role key — bypasses RLS. Dashboard → Settings → API → service_role.
# REQUIRED. Keep secret — never expose in the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase JWT secret for HS256 token verification. Dashboard → Settings → API → JWT Settings.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Encryption (REQUIRED) ─────────────────────────────────────────────────────
# Fernet key for AES-128 field-level encryption of financial data at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_MASTER_KEY=your-fernet-key-base64url-here

# ── Stripe (REQUIRED) ─────────────────────────────────────────────────────────
# Stripe secret key. Dashboard → Developers → API keys → Secret key.
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key

# Stripe webhook signing secret. Dashboard → Webhooks → your endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Stripe Price IDs. Dashboard → Products → your product → Prices.
STRIPE_PRICE_SINGLE_REPORT=price_your-single-report-price-id
STRIPE_PRICE_UNLIMITED_MONTHLY=price_your-unlimited-monthly-price-id

# Stripe coupon ID for the 20% referral discount. Dashboard → Coupons.
STRIPE_REFERRAL_COUPON_ID=REFER20

# ── CORS (REQUIRED) ───────────────────────────────────────────────────────────
# Comma-separated allowed origins. No trailing slash, no wildcards.
# Example: https://neufin.ai,https://neufin-web.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Sentry (optional — error tracking disabled when empty) ───────────────────
# Sentry DSN. sentry.io → your project → Settings → Client Keys → DSN.
SENTRY_DSN=

# Sentry performance traces sample rate (0.0–1.0). 0.1 = 10% in production.
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Logging ───────────────────────────────────────────────────────────────────
# "json" for production (structured), "console" for local development (coloured).
LOG_FORMAT=console

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Market data providers (all optional — app degrades gracefully) ────────────
# Polygon.io — primary batch price source. polygon.io → Dashboard → API Keys.
POLYGON_API_KEY=

# Finnhub — real-time price fallback. finnhub.io → Dashboard → API key.
FINNHUB_API_KEY=

# Financial Modeling Prep — batch price fallback. financialmodelingprep.com → Dashboard.
FMP_API_KEY=

# Twelve Data — price fallback. twelvedata.com → Dashboard.
TWELVEDATA_API_KEY=

# Marketstack — price fallback. marketstack.com → Dashboard.
MARKETSTACK_API_KEY=

# Alpha Vantage — correlation matrix + price fallback. alphavantage.co → Get Free API Key.
ALPHA_VANTAGE_API_KEY=

# Federal Reserve Economic Data — macro indicators. fred.stlouisfed.org → My Account → API Keys.
FRED_API_KEY=

# Delay (seconds) between Alpha Vantage requests to avoid rate limits (free tier = 12 req/min).
AV_REQUEST_DELAY=0.0

# ── AI providers (all optional — waterfall: Claude → GPT-4o → Gemini → Groq) ─
# Anthropic Claude. console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# OpenAI GPT-4o. platform.openai.com → API keys.
OPENAI_KEY=

# Google Gemini. aistudio.google.com → Get API key.
GEMINI_KEY=

# Groq (Llama 3). console.groq.com → API Keys.
GROQ_KEY=

# ── Cache / task queue (optional) ────────────────────────────────────────────
# Redis URL. Leave empty to disable Redis caching.
# Format: redis://default:password@host:6379
REDIS_URL=

# ── App ───────────────────────────────────────────────────────────────────────
# Frontend base URL used in share links (e.g. https://neufin.ai).
APP_BASE_URL=http://localhost:3000

# HTTP port (Railway injects PORT automatically — no need to set in production).
PORT=8000

# ── Agent OS / router-system (optional) ──────────────────────────────────────
# Base URL of the Agent OS router-system for service registration + heartbeats.
AGENT_OS_URL=https://ctech-production.up.railway.app

# API key for the Agent OS router-system. Leave empty to skip registration.
AGENT_OS_API_KEY=

# ── Git / deployment metadata ─────────────────────────────────────────────────
# Git commit SHA injected at build time. Set via Railway build-time variable.
GIT_COMMIT_SHA=unknown

# ── Dev-only overrides ────────────────────────────────────────────────────────
# Skip JWT verification — NEVER set true in production.
BYPASS_AUTH_IN_DEV=false
